<%- include('partials/head', { title: 'Products | adminHMD', description: 'Manage products' }) %>
<body>
  <div class="admin-shell">
    <div class="sidebar-backdrop" data-sidebar-close></div>
    <%- include('partials/sidebar', { activePage: 'viewProducts' }) %>
    <div class="admin-main">
      <%- include('partials/navbar') %>
      <main class="dashboard-content">
        <div class="container-fluid px-3 px-lg-4 py-4">
          <div class="page-heading">
            <div class="page-heading-copy">
              <span class="page-icon"><i class="bi bi-box-seam" aria-hidden="true"></i></span>
              <div>
                <p class="eyebrow mb-1">Catalog</p>
                <h1 class="h3 mb-1">Products</h1>
                <p class="text-muted mb-0">Review and manage your product inventory.</p>
              </div>
            </div>
            <div class="heading-actions">
              <a href="/pages/product/add" class="btn btn-primary btn-sm">Add Product</a>
            </div>
          </div>

          <section class="panel mt-3">
            <div class="table-responsive">
              <table class="table align-middle mb-0">
                <thead>
                  <tr>
                    <th>Image</th>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th class="text-end">Action</th>
                  </tr>
                </thead>
                <tbody>
                  <% products.forEach((product) => { %>
                    <tr>
                      <td>
                        <% if (product.image) { %>
                          <img src="<%= product.image %>" alt="<%= product.name %>" style="width: 48px; height: 48px; object-fit: cover; border-radius: 8px;">
                        <% } else { %>
                          <span class="text-muted">No image</span>
                        <% } %>
                      </td>
                      <td><strong><%= product.name %></strong></td>
                      <td><%= product.category ? product.category.name : '-' %></td>
                      <td>$<%= product.price.toFixed(2) %></td>
                      <td><%= product.stock %></td>
                      <td class="text-end">
                        <a href="/pages/product/<%= product._id %>/edit" class="btn btn-light btn-sm">Edit</a>
                        <form action="/pages/product/<%= product._id %>/delete" method="POST" class="d-inline">
                          <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                        </form>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </section>
        </div>
      </main>
    </div>
  </div>
  <script src="/public/js/bootstrap.bundle.min.js"></script>
  <script src="/public/js/main.js"></script>
</body>
</html>
