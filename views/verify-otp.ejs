<%- include('partials/head', { title: 'Verify OTP | adminHMD', description: 'Verify your OTP for password reset' }) %>

<body class="auth-body">
  <main class="auth-page">
    <section class="auth-card">
      <a class="auth-brand" href="/auth/login"><span class="brand-icon"><i class="bi bi-grid-1x2-fill" aria-hidden="true"></i></span><span><strong>adminHMD</strong><small>Verify the OTP sent to your email.</small></span></a>
      <form class="needs-validation" action="/auth/verify-otp" method="post">
        <div class="mb-4">
          <p class="eyebrow mb-1">Security</p>
          <h1 class="h3 mb-1">Verify OTP</h1>
          <p class="text-muted mb-0">Enter the 6-digit code we generated for your account.</p>
        </div>

        <% if (error) { %>
          <div class="alert alert-danger" role="alert"><%= error %></div>
        <% } %>
        <% if (success) { %>
          <div class="alert alert-success" role="alert"><%= success %></div>
        <% } %>

        <input type="hidden" name="userId" value="<%= userId || '' %>">
        <div class="mb-3">
          <label class="form-label" for="otp">OTP</label>
          <input class="form-control" id="otp" name="otp" type="text" inputmode="numeric" maxlength="6" required>
        </div>
        <button class="btn btn-primary w-100" type="submit">Verify OTP</button>
      </form>

      <div class="auth-footer"><a href="/auth/forgot-password">Back</a></div>
    </section>
  </main>

  <%- include('partials/scripts') %>
</body>
</html>
