<%- include('partials/head', { title: 'Reset Password | adminHMD', description: 'Set a new password' }) %>

<body class="auth-body">
  <main class="auth-page">
    <section class="auth-card">
      <a class="auth-brand" href="/auth/login"><span class="brand-icon"><i class="bi bi-grid-1x2-fill" aria-hidden="true"></i></span><span><strong>adminHMD</strong><small>Create a new password.</small></span></a>
      <form class="needs-validation" action="/auth/reset-password" method="post">
        <div class="mb-4">
          <p class="eyebrow mb-1">Security</p>
          <h1 class="h3 mb-1">Reset Password</h1>
          <p class="text-muted mb-0">Choose a new password for your account.</p>
        </div>

        <% if (error) { %>
          <div class="alert alert-danger" role="alert"><%= error %></div>
        <% } %>
        <% if (success) { %>
          <div class="alert alert-success" role="alert"><%= success %></div>
        <% } %>

        <input type="hidden" name="userId" value="<%= userId || '' %>">
        <div class="mb-3">
          <label class="form-label" for="password">New Password</label>
          <input class="form-control" id="password" name="password" type="password" minlength="6" required>
        </div>
        <div class="mb-3">
          <label class="form-label" for="confirmPassword">Confirm Password</label>
          <input class="form-control" id="confirmPassword" name="confirmPassword" type="password" minlength="6" required>
        </div>
        <button class="btn btn-primary w-100" type="submit">Reset Password</button>
      </form>

      <div class="auth-footer"><a href="/auth/login">Back to login</a></div>
    </section>
  </main>

  <%- include('partials/scripts') %>
</body>
</html>
