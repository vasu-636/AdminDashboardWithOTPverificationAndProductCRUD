<%- include('partials/head', { title: 'Categories | adminHMD', description: 'Manage categories' }) %>
<body>
  <div class="admin-shell">
    <div class="sidebar-backdrop" data-sidebar-close></div>
    <%- include('partials/sidebar', { activePage: 'viewCategories' }) %>
    <div class="admin-main">
      <%- include('partials/navbar') %>
      <main class="dashboard-content">
        <div class="container-fluid px-3 px-lg-4 py-4">
          <div class="page-heading">
            <div class="page-heading-copy">
              <span class="page-icon"><i class="bi bi-tags" aria-hidden="true"></i></span>
              <div>
                <p class="eyebrow mb-1">Catalog</p>
                <h1 class="h3 mb-1">Categories</h1>
                <p class="text-muted mb-0">Review and manage your category list.</p>
              </div>
            </div>
            <div class="heading-actions">
              <a href="/pages/category/add" class="btn btn-primary btn-sm">Add Category</a>
            </div>
          </div>

          <% if (typeof successMessages !== 'undefined' && successMessages.length) { %>
            <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
              <i class="bi bi-check-circle me-2"></i>
              <% successMessages.forEach((message) => { %>
                <span><%= message %></span>
              <% }) %>
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
          <% } %>
          <% if (typeof errorMessages !== 'undefined' && errorMessages.length) { %>
            <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
              <i class="bi bi-exclamation-triangle me-2"></i>
              <% errorMessages.forEach((message) => { %>
                <span><%= message %></span>
              <% }) %>
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
          <% } %>

          <section class="panel mt-3">
            <div class="table-responsive">
              <table class="table align-middle mb-0">
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Created</th>
                    <th class="text-end">Action</th>
                  </tr>
                </thead>
                <tbody>
                  <% categories.forEach((category) => { %>
                    <tr>
                      <td><strong><%= category.name %></strong></td>
                      <td><%= category.description || '-' %></td>
                      <td><%= new Date(category.createdAt).toLocaleDateString() %></td>
                      <td class="text-end">
                        <a href="/pages/category/<%= category._id %>/edit" class="btn btn-light btn-sm">Edit</a>
                        <form action="/pages/category/<%= category._id %>/delete" method="POST" class="d-inline">
                          <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                        </form>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </section>
        </div>
      </main>
    </div>
  </div>
  <script src="/public/js/bootstrap.bundle.min.js"></script>
  <script src="/public/js/main.js"></script>
</body>
</html>
