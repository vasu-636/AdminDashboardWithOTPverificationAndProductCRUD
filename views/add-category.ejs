<%- include('partials/head', { title: 'Add Category | adminHMD', description: 'Create a new category' }) %>
<body>
  <div class="admin-shell">
    <div class="sidebar-backdrop" data-sidebar-close></div>
    <%- include('partials/sidebar', { activePage: 'addCategory' }) %>
    <div class="admin-main">
      <%- include('partials/navbar') %>
      <main class="dashboard-content">
        <div class="container-fluid px-3 px-lg-4 py-4">
          <div class="page-heading">
            <div class="page-heading-copy">
              <span class="page-icon"><i class="bi bi-tags" aria-hidden="true"></i></span>
              <div>
                <p class="eyebrow mb-1">Catalog</p>
                <h1 class="h3 mb-1">Add Category</h1>
                <p class="text-muted mb-0">Create a new product category for your catalog.</p>
              </div>
            </div>
          </div>

          <section class="panel mt-3">
            <form action="/pages/category/add" method="POST" class="row g-3">
              <div class="col-md-6">
                <label class="form-label" for="name">Category Name</label>
                <input type="text" class="form-control" id="name" name="name" required>
              </div>
              <div class="col-md-6">
                <label class="form-label" for="description">Description</label>
                <input type="text" class="form-control" id="description" name="description">
              </div>
              <div class="col-12">
                <button type="submit" class="btn btn-primary">Save Category</button>
                <a href="/pages/categories" class="btn btn-outline-secondary ms-2">Back</a>
              </div>
            </form>
          </section>
        </div>
      </main>
    </div>
  </div>
  <script src="/public/js/bootstrap.bundle.min.js"></script>
  <script src="/public/js/main.js"></script>
</body>
</html>
