<%- include('partials/head', { title: 'Forgot Password | adminHMD', description: 'Reset your password' }) %>

<body class="auth-body">
  <main class="auth-page">
    <section class="auth-card">
      <a class="auth-brand" href="/auth/login"><span class="brand-icon"><i class="bi bi-grid-1x2-fill" aria-hidden="true"></i></span><span><strong>adminHMD</strong><small>Reset your password.</small></span></a>
      <form class="needs-validation" action="/auth/forgot-password" method="post">
        <div class="mb-4">
          <p class="eyebrow mb-1">Security</p>
          <h1 class="h3 mb-1">Forgot Password</h1>
          <p class="text-muted mb-0">Enter your email and we will prepare a reset link for you.</p>
        </div>

        <% if (error) { %>
          <div class="alert alert-danger" role="alert"><%= error %></div>
        <% } %>
        <% if (success) { %>
          <div class="alert alert-success" role="alert"><%= success %></div>
        <% } %>
        <div class="mb-3">
          <label class="form-label" for="email">Email address</label>
          <input class="form-control" id="email" name="email" type="email" required>
        </div>
        <button class="btn btn-primary w-100" type="submit">Send Reset Link</button>
      </form>

      <div class="auth-footer"><a href="/auth/login">Back to login</a></div>
    </section>
  </main>

  <%- include('partials/scripts') %>
</body>
</html>
