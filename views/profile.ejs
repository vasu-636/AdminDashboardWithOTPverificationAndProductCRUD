<%- include('partials/head', { title: 'Profile | adminHMD', description: 'adminHMD professional admin dashboard template' }) %>

<body>
  <div class="admin-shell">
    <div class="sidebar-backdrop" data-sidebar-close></div>

    <%- include('partials/sidebar', { activePage: 'profile' }) %>

    <div class="admin-main">
      <%- include('partials/navbar') %>

      <main class="dashboard-content">
        <div class="container-fluid px-3 px-lg-4 py-4">
          <div class="page-heading">
            <div class="page-heading-copy">
              <span class="page-icon"><i class="bi bi-person-badge" aria-hidden="true"></i></span>
              <div>
                <p class="eyebrow mb-1">Account</p>
                <h1 class="h3 mb-1">Profile</h1>
                <p class="text-muted mb-0">Manage your personal details, bio, and contact preferences.</p>
              </div>
            </div>
            
          </div>

          <section class="row g-3">
            <div class="col-12 col-xl-4">
              <div class="panel h-100 text-center profile-card">
                <div class="profile-cover"><img src="/public/images/png/dasher-ui-bootstrap-5.jpg" alt="adminHMD dashboard preview"></div>
                <img class="avatar-img avatar-xl profile-photo" src="<%= user && user.profileImage ? user.profileImage : '/public/images/avatar/avatar.jpg' %>" alt="<%= user ? user.name : 'User' %>">
                <h2 class="h5 mt-3 mb-1"><%= user ? user.name : 'User' %></h2>
                <p class="text-muted mb-3"><%= user && user.bio ? user.bio : 'Product Administrator' %></p>
                <div class="d-flex justify-content-center gap-2"><span class="badge text-bg-primary">Admin</span><span class="badge text-bg-success">Verified</span></div>
                <div class="info-list mt-4 text-start"><div><span>Email</span><strong><%= user ? user.email : 'N/A' %></strong></div><div><span>Phone</span><strong><%= user && user.phoneNumber ? user.phoneNumber : 'Not added yet' %></strong></div><div><span>Bio</span><strong><%= user && user.bio ? user.bio : 'No bio yet' %></strong></div></div>
              </div>
            </div>
            <div class="col-12 col-xl-8">
              <div class="panel">
                <div class="panel-header">
                  <div>
                    <h2 class="h5 mb-1 section-title"><i class="bi bi-person-gear" aria-hidden="true"></i><span>Profile Summary</span></h2>
                    <p class="text-muted mb-0">Your public profile details are shown here. Use edit profile to make changes.</p>
                  </div>
                  <a class="btn btn-primary" href="/pages/profile/edit"><i class="bi bi-pencil-square" aria-hidden="true"></i> Edit Profile</a>
                </div>
                <div class="row g-3">
                  <div class="col-12"><label class="form-label">Name</label><p class="form-control-plaintext fw-semibold"><%= user ? user.name : 'User' %></p></div>
                  <div class="col-md-6"><label class="form-label">Email</label><p class="form-control-plaintext"><%= user ? user.email : 'N/A' %></p></div>
                  <div class="col-md-6"><label class="form-label">Contact Number</label><p class="form-control-plaintext"><%= user && user.phoneNumber ? user.phoneNumber : 'Not added yet' %></p></div>
                  <div class="col-12"><label class="form-label">Bio</label><p class="form-control-plaintext"><%= user && user.bio ? user.bio : 'No bio yet' %></p></div>
                </div>
              </div>
            </div>
          </section>
        </div>
      </main>

      <%- include('partials/footer') %>
    </div>
  </div>

  <%- include('partials/scripts') %>
</body>
</html>
